# ─── Supabase ──────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── BuildPad DaaS ─────────────────────────────────────────────────────────────
# Your BuildPad DaaS backend URL (no trailing slash)
BUILDPAD_DAAS_URL=https://your-daas-instance.buildpad.dev

# ─── AI Service ────────────────────────────────────────────────────────────────
# Deployed FastAPI microservice URL (Railway / Render)
# Can also be set in system_config collection via DaaS admin panel
AI_SERVICE_URL=https://your-ai-service.railway.app

# ─── Role Configuration ────────────────────────────────────────────────────────
# The DaaS role ID for the "Operator" role.
# If not set, the signup route will look it up by name automatically.
# Find it: DaaS Admin → Access Control → Roles → Operator → copy ID
OPERATOR_ROLE_ID=
